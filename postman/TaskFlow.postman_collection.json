{
	"info": {
		"_postman_id": "taskflow-api-collection",
		"name": "TaskFlow API",
		"description": "Task management REST API built with Go, PostgreSQL, and Docker.\n\n## Setup\n1. Run `docker compose up --build`\n2. API available at http://localhost:8080\n3. Seed data is loaded automatically\n\n## Test Credentials\n- Email: test@example.com\n- Password: password123\n\n## Usage\nRun requests in order: Auth → Projects → Tasks.\nThe login request auto-saves the JWT token for subsequent requests.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:8080",
			"type": "string"
		},
		{
			"key": "token",
			"value": "",
			"type": "string"
		},
		{
			"key": "projectId",
			"value": "b1eebc99-9c0b-4ef8-bb6d-6bb9bd380a22",
			"type": "string"
		},
		{
			"key": "taskId",
			"value": "c1eebc99-9c0b-4ef8-bb6d-6bb9bd380a31",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "Auth",
			"description": "Register and login endpoints. No auth header required.",
			"item": [
				{
					"name": "Register",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const json = pm.response.json();",
									"if (json.token) {",
									"    pm.collectionVariables.set('token', json.token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"New User\",\n    \"email\": \"newuser@example.com\",\n    \"password\": \"password123\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/auth/register",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "register"]
						}
					}
				},
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const json = pm.response.json();",
									"if (json.token) {",
									"    pm.collectionVariables.set('token', json.token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"test@example.com\",\n    \"password\": \"password123\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/auth/login",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "login"]
						}
					}
				}
			]
		},
		{
			"name": "Projects",
			"description": "CRUD operations for projects. All requests require Bearer token.",
			"item": [
				{
					"name": "List Projects",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/projects?page=1&limit=20",
							"host": ["{{baseUrl}}"],
							"path": ["projects"],
							"query": [
								{
									"key": "page",
									"value": "1"
								},
								{
									"key": "limit",
									"value": "20"
								}
							]
						}
					}
				},
				{
					"name": "Create Project",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const json = pm.response.json();",
									"if (json.id) {",
									"    pm.collectionVariables.set('projectId', json.id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Website Redesign\",\n    \"description\": \"Q2 redesign of the company website\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/projects",
							"host": ["{{baseUrl}}"],
							"path": ["projects"]
						}
					}
				},
				{
					"name": "Get Project By ID",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/projects/{{projectId}}",
							"host": ["{{baseUrl}}"],
							"path": ["projects", "{{projectId}}"]
						}
					}
				},
				{
					"name": "Get Project Stats",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/projects/{{projectId}}/stats",
							"host": ["{{baseUrl}}"],
							"path": ["projects", "{{projectId}}", "stats"]
						}
					}
				},
				{
					"name": "Update Project",
					"request": {
						"method": "PATCH",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Website Redesign v2\",\n    \"description\": \"Updated project description\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/projects/{{projectId}}",
							"host": ["{{baseUrl}}"],
							"path": ["projects", "{{projectId}}"]
						}
					}
				},
				{
					"name": "Delete Project",
					"request": {
						"method": "DELETE",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/projects/{{projectId}}",
							"host": ["{{baseUrl}}"],
							"path": ["projects", "{{projectId}}"]
						}
					}
				}
			]
		},
		{
			"name": "Tasks",
			"description": "CRUD operations for tasks within projects. All requests require Bearer token.",
			"item": [
				{
					"name": "List Tasks",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/projects/{{projectId}}/tasks?page=1&limit=20",
							"host": ["{{baseUrl}}"],
							"path": ["projects", "{{projectId}}", "tasks"],
							"query": [
								{
									"key": "page",
									"value": "1"
								},
								{
									"key": "limit",
									"value": "20"
								}
							]
						}
					}
				},
				{
					"name": "List Tasks - Filter by Status",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/projects/{{projectId}}/tasks?status=todo",
							"host": ["{{baseUrl}}"],
							"path": ["projects", "{{projectId}}", "tasks"],
							"query": [
								{
									"key": "status",
									"value": "todo"
								}
							]
						}
					}
				},
				{
					"name": "List Tasks - Filter by Assignee",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/projects/{{projectId}}/tasks?assignee=a0eebc99-9c0b-4ef8-bb6d-6bb9bd380a11",
							"host": ["{{baseUrl}}"],
							"path": ["projects", "{{projectId}}", "tasks"],
							"query": [
								{
									"key": "assignee",
									"value": "a0eebc99-9c0b-4ef8-bb6d-6bb9bd380a11"
								}
							]
						}
					}
				},
				{
					"name": "Create Task",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const json = pm.response.json();",
									"if (json.id) {",
									"    pm.collectionVariables.set('taskId', json.id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"title\": \"Design homepage mockup\",\n    \"description\": \"Create wireframes and high-fidelity mockups\",\n    \"status\": \"todo\",\n    \"priority\": \"high\",\n    \"assignee_id\": \"a0eebc99-9c0b-4ef8-bb6d-6bb9bd380a11\",\n    \"due_date\": \"2026-04-30\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/projects/{{projectId}}/tasks",
							"host": ["{{baseUrl}}"],
							"path": ["projects", "{{projectId}}", "tasks"]
						}
					}
				},
				{
					"name": "Update Task",
					"request": {
						"method": "PATCH",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"status\": \"in_progress\",\n    \"priority\": \"medium\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/tasks/{{taskId}}",
							"host": ["{{baseUrl}}"],
							"path": ["tasks", "{{taskId}}"]
						}
					}
				},
				{
					"name": "Delete Task",
					"request": {
						"method": "DELETE",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/tasks/{{taskId}}",
							"host": ["{{baseUrl}}"],
							"path": ["tasks", "{{taskId}}"]
						}
					}
				}
			]
		}
	]
}
