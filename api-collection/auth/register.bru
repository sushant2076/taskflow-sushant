meta {
  name: Register
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/auth/register
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "name": "New User",
    "email": "newuser@example.com",
    "password": "password123"
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setVar("token", res.body.token);
  }
}
